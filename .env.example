# API endpoints
WEATHER_ENDPOINT=https://archive-api.open-meteo.com/v1/archive
SOIL_ENDPOINT=https://rest.isric.org/soilgrids/v2.0/properties/query

# Request behavior
REQUEST_TIMEOUT_SECONDS=15
REQUEST_RETRIES=3
REQUEST_BACKOFF_BASE_SECONDS=0.8
REQUEST_BACKOFF_MAX_SECONDS=8
WEATHER_MIN_INTERVAL_SECONDS=0.08
SOIL_MIN_INTERVAL_SECONDS=0.7
WEATHER_WORKERS=8
FAILURE_ABORT_RATIO=0.45

# Runtime defaults
DEFAULT_SEED=42
DEFAULT_POINTS=100
DEFAULT_TOP_N=10
# Optional fixed dates. If omitted, app uses rolling 3-year window.
# DEFAULT_START_DATE=2023-01-01
# DEFAULT_END_DATE=2025-12-31

# Output directories
CACHE_DIR=.cache
RUNS_DIR=runs

# Optional LLM thinker mode (Ollama + Llama 3)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
LLM_TIMEOUT_SECONDS=20
LLM_MAX_POINTS=25

